OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_HELPER_DAILY_LIMIT=80
SITE_URL=https://urbanyards.us
# Optional local invite callback override. Only use localhost here during explicit local auth testing.
VITE_SITE_URL=
ALLOWED_ORIGINS=https://urbanyards.us,https://www.urbanyards.us
APP_ENV=production

# Supabase dashboard auth and quote archive.
VITE_SUPABASE_URL=https://gvdeqqrbonulwgmgpgis.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_DASHBOARD_OWNER_EMAIL=team@urbanyards.us
DASHBOARD_OWNER_EMAIL=team@urbanyards.us
DASHBOARD_ADMIN_EMAILS=team@urbanyards.us
SUPABASE_URL=https://gvdeqqrbonulwgmgpgis.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FUNCTION_TIMEOUT_MS=10000

# Optional Square invoice lookup for /pay.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_VERSION=2025-06-18
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=https://urbanyards.us/api/square-webhook

# At least one quote delivery channel is required.
RESEND_API_KEY=
QUOTE_TO_EMAIL=team@urbanyards.us
QUOTE_FROM_EMAIL=Urban Yards Website <quotes@urbanyards.us>
QUOTE_WEBHOOK_URL=
QUOTE_WEBHOOK_SECRET=

# Optional lead archive and protected CSV export.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Quote Requests
ADMIN_EXPORT_TOKEN=

# Optional permanent photo storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=urban-yards/quote-requests
CLOUDINARY_DELIVERY_TYPE=authenticated

# Optional fail-closed malware scanner. It must return JSON: {"clean": true}.
MALWARE_SCAN_URL=
MALWARE_SCAN_TOKEN=

# Retention and customer deletion requests.
LEAD_RETENTION_DAYS=180
RETENTION_JOB_SECRET=
PRIVACY_REQUEST_WEBHOOK_URL=
PRIVACY_REQUEST_WEBHOOK_SECRET=

# Redacted security alerts. Supports Slack-compatible or custom webhooks.
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_SECRET=

# Optional Cloudflare Turnstile protection.
TURNSTILE_SECRET_KEY=
