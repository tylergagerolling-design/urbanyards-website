{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Urban Yards Property Intelligence Profile",
  "type": "object",
  "required": ["propertyId", "address", "propertyType"],
  "properties": {
    "propertyId": { "type": "string" },
    "address": { "type": "string" },
    "propertyType": { "type": "string" },
    "serviceFrequency": { "type": "string" },
    "accessDetails": { "type": "array", "items": { "type": "string" } },
    "parkingInstructions": { "type": "array", "items": { "type": "string" } },
    "contactIds": { "type": "array", "items": { "type": "string" } },
    "serviceBoundaries": { "type": "array", "items": { "type": "string" } },
    "lawnAreas": { "type": "array", "items": { "type": "object" } },
    "bedAreas": { "type": "array", "items": { "type": "object" } },
    "plantInventory": { "type": "array", "items": { "type": "object" } },
    "treeInventory": { "type": "array", "items": { "type": "object" } },
    "irrigationSystem": { "type": ["object", "null"] },
    "irrigationZones": { "type": "array", "items": { "type": "object" } },
    "drainageConditions": { "type": "array", "items": { "type": "string" } },
    "soilConditions": { "type": "array", "items": { "type": "string" } },
    "exposure": { "type": "array", "items": { "type": "string" } },
    "slopes": { "type": "array", "items": { "type": "string" } },
    "hazards": { "type": "array", "items": { "type": "string" } },
    "petConcerns": { "type": "array", "items": { "type": "string" } },
    "childSafetyConcerns": { "type": "array", "items": { "type": "string" } },
    "noiseRestrictions": { "type": "array", "items": { "type": "string" } },
    "disposalRules": { "type": "array", "items": { "type": "string" } },
    "clientPreferences": { "type": "array", "items": { "type": "string" } },
    "photoIds": { "type": "array", "items": { "type": "string" } },
    "previousWorkIds": { "type": "array", "items": { "type": "string" } },
    "openRecommendationIds": { "type": "array", "items": { "type": "string" } },
    "recurringProblems": { "type": "array", "items": { "type": "string" } },
    "seasonalNotes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
