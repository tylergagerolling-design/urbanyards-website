{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urbanyards.us/schemas/landscaping-knowledge-record.json",
  "title": "Urban Yards Landscaping Knowledge Record",
  "type": "object",
  "required": ["id", "title", "layer", "category", "summary", "confidenceLevel", "lastReviewedDate", "version", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "title": { "type": "string", "maxLength": 180 },
    "layer": { "enum": ["general", "regional", "company", "safety"] },
    "category": { "type": "string", "maxLength": 100 },
    "subcategory": { "type": "string", "maxLength": 100 },
    "aliases": { "type": "array", "items": { "type": "string", "maxLength": 80 }, "maxItems": 24 },
    "summary": { "type": "string", "maxLength": 800 },
    "detail": { "type": "string", "maxLength": 5000 },
    "region": { "type": "array", "items": { "type": "string" }, "maxItems": 12 },
    "climateZone": { "type": "array", "items": { "type": "string" }, "maxItems": 12 },
    "seasons": { "type": "array", "items": { "enum": ["winter", "spring", "summer", "fall", "year-round"] } },
    "propertyTypes": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "jobTypes": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "triggers": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "requiredObservations": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "tools": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "materials": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "ppe": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "preparationSteps": { "type": "array", "items": { "type": "string" }, "maxItems": 40 },
    "procedureSteps": { "type": "array", "items": { "type": "string" }, "maxItems": 60 },
    "qualityStandard": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "commonMistakes": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "prohibitedActions": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "safetyWarnings": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "environmentalConcerns": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "licensingConcerns": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "escalationConditions": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "laborConsiderations": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "relatedRecords": { "type": "array", "items": { "type": "string" }, "maxItems": 30 },
    "sources": { "type": "array", "items": { "type": "object", "required": ["title"], "properties": { "title": { "type": "string" }, "url": { "type": "string" }, "reviewed": { "type": "string", "format": "date" } } } },
    "confidenceLevel": { "enum": ["low", "medium", "high"] },
    "lastReviewedDate": { "type": "string", "format": "date" },
    "version": { "type": "integer", "minimum": 1 },
    "reviewFrequencyDays": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "approved", "retired"] }
  },
  "additionalProperties": false
}
